# HTTP port used by the application server.
PORT=3000

# Exact browser origin allowed to connect to Socket.IO.
# Set this to the public application URL in production.
APP_ORIGIN=http://localhost:3000

# Optional canonical browser URL used when generating multiplayer invite links.
# Leave unset when the public site and Socket.IO server use the same address.
VITE_PUBLIC_APP_URL=

# Trust X-Forwarded-For only when a trusted reverse proxy overwrites that header
# and direct access to this Node server is blocked.
TRUST_PROXY=false
